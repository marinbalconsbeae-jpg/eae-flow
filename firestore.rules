rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ─── UTILISATEURS ───────────────────────────────────────────────────────
    match /utilisateurs/{uid} {
      // Tout utilisateur authentifié peut lire tous les profils
      allow read: if isAuthenticated();

      // Seul l'Admin SDK (agent Python) peut créer/modifier
      allow write: if false;
    }

    // ─── SAISIES ────────────────────────────────────────────────────────────
    match /saisies/{saisieId} {
      // Tout utilisateur authentifié peut lire toutes les saisies
      allow read: if isAuthenticated();

      // Écriture uniquement sur ses propres saisies (tech_id == uid)
      allow write: if isAuthenticated()
        && request.auth.uid == request.resource.data.tech_id;
    }

    // ─── SUPPRESSIONS (queue agent Python) ──────────────────────────────────
    match /suppressions/{uid} {
      allow create: if isOwner(uid);
      allow read, delete: if false;
    }

    // Tout le reste est refusé par défaut
  }
}
