rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isCA() {
      return isAuthenticated()
        && get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data.role == "charge_affaires";
    }

    // ─── UTILISATEURS ───────────────────────────────────────────────────────
    match /utilisateurs/{uid} {
      // Tout utilisateur authentifié peut lire tous les profils
      allow read: if isAuthenticated();

      // Un CA peut créer un technicien rattaché à lui
      allow create: if isCA()
        && request.resource.data.role == "technicien"
        && request.resource.data.charge_id == request.auth.uid;

      // Modification :
      //  - un CA modifie ses propres techniciens (tous champs), OU
      //  - tout utilisateur modifie UNIQUEMENT son propre champ email (pas role/charge_id)
      allow update: if (isCA() && resource.data.charge_id == request.auth.uid)
        || (isOwner(uid)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['email']));

      // Un CA peut supprimer uniquement ses propres techniciens
      allow delete: if isCA()
        && resource.data.charge_id == request.auth.uid;
    }

    // ─── SAISIES ────────────────────────────────────────────────────────────
    match /saisies/{saisieId} {
      // Tout utilisateur authentifié peut lire toutes les saisies
      allow read: if isAuthenticated();

      // Création : le doc doit être à SON chemin (uid_date) et tech_id == uid
      // → empêche d'écrire à l'emplacement d'un autre technicien
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.tech_id
        && saisieId == request.auth.uid + "_" + request.resource.data.date;

      // Modification : uniquement une saisie qu'on possède déjà, sans changer le propriétaire
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.tech_id
        && request.auth.uid == request.resource.data.tech_id;
    }

    // ─── SUPPRESSIONS (queue agent Python) ──────────────────────────────────
    match /suppressions/{uid} {
      // Un CA peut mettre en file la suppression d'un de ses techniciens
      allow create: if isCA()
        && get(/databases/$(database)/documents/utilisateurs/$(uid)).data.charge_id == request.auth.uid;
      allow read, delete: if false;
    }

    // ─── FOURNISSEURS ────────────────────────────────────────────────────────
    match /fournisseurs/{fourId} {
      // Tout utilisateur authentifié peut lire (dropdowns, agent Python)
      allow read: if isAuthenticated();
      // Tout CA authentifié peut créer/modifier/supprimer
      allow write: if isCA();
    }

    // ─── MISSIONS PERSONNALISÉES (par CA) ────────────────────────────────────
    match /missions_custom/{missionId} {
      // Un CA peut créer une mission, à condition qu'elle lui soit rattachée
      allow create: if isCA() && request.resource.data.ca_id == request.auth.uid;
      // Un CA peut lire/modifier/supprimer UNIQUEMENT ses propres missions
      allow read, update, delete: if isCA() && resource.data.ca_id == request.auth.uid;
    }

    // Tout le reste est refusé par défaut
  }
}
